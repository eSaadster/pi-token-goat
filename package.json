{
  "name": "token-goat",
  "version": "0.0.0-seed",
  "description": "TypeScript/Node port of token-goat (seed scaffold: entropy).",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "esbuild src/token_goat/main.ts --bundle --platform=node --format=esm --packages=external --banner:js='#!/usr/bin/env node' --outfile=dist/token-goat.mjs && chmod +x dist/token-goat.mjs",
    "build:lib": "esbuild src/token_goat/index.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/token-goat-lib.mjs"
  },
  "bin": {
    "token-goat": "dist/token-goat.mjs"
  },
  "files": [
    "dist/"
  ],
  "devDependencies": {
    "@types/node": "^22.10.2",
    "esbuild": "^0.24.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.11.1",
    "commander": "^15.0.0",
    "sharp": "^0.35.2",
    "smol-toml": "^1.6.1",
    "sqlite-vec": "^0.1.9",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.25.10"
  }
}
